# Production env vars (set these in Railway)
DJANGO_SETTINGS_MODULE=backend.settings.prod
SECRET_KEY=generate-a-long-random-string
DEBUG=False

# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Comma-separated. Use the Railway-assigned domain (no protocol).
ALLOWED_HOSTS=your-railway-subdomain.up.railway.app

# Comma-separated full origins (with protocol).
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Invoice template (optional — safe defaults in settings)
COMPANY_NAME=AutoCare Service Center
COMPANY_ADDRESS=123 MG Road, Bengaluru, Karnataka 560001
COMPANY_GSTIN=29AABCU9603R1ZM
